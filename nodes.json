[
  {
    "id": "obj_det_yolo",
    "name": "YOLO Object Detection",
    "image": "ghcr.io/phsilvarepo/yolov11-ros2-humble-base:latest",
    "category": "Computer Vision",
    "description": "High-speed 2D detection for common spatial objects.",
    "params": {
      "input_type": "sensor_msgs/msg/Image",
      "output_type": "sensor_msgs/msg/Image",
      "default_model": "yolo11n.pt",
      "default_conf": "0.5",
      "default_res": "640",
      "model_options": ["yolo11n.pt", "yolo11m.pt", "yolo11l.pt", "custom"]
    },
    "launch_args": ["confidence_threshold", "output_topic", "model_path", "image_resolution"]
  },
  {
    "id": "leaf_seg",
    "name": "Instance Segmentation",
    "image": "ghcr.io/phsilvarepo/yolov11-ros2:latest",
    "category": "Agriculture AI",
    "description": "Pixel-level masking for organic material separation.",
    "params": {
      "input_type": "sensor_msgs/msg/Image",
      "output_type": "sensor_msgs/msg/Image",
      "default_model": "/ros_ws/src/yolov11_ros2/leaf_seg.pt"
    },
    "launch_args": ["mask_opacity"]
